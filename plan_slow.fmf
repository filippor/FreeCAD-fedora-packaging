summary:
    Run FreeCAD slow tests
prepare+:
  - how: install
    package:
      - gmsh
      - calculix-ccx
      - python3-pip
      - python3-numpy
  - how: shell
    script:
      - python3 -m pip install --user --no-deps pyNastran
discover:
    how: fmf
    path: tests
    test:
      - /slow_tests/*
execute:
    how: tmt
