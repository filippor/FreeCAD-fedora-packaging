/tests:
  /coin_snapshot_tests:
    /TestCoinNodeSnapshots:
      test: |
        set +e

        OUT="${TMT_TEST_DATA:-/tmp/FreeCADTesting}/CoinNodeSnapshots"
        mkdir -p "$OUT"

        echo "Running FreeCAD visual tests..."
        FC_VISUAL_UPDATE_BASELINE=0 FC_TESTS_DIR=/usr/share/freecad/tests FC_VISUAL_OUT_DIR="$OUT" wlheadless-run --width=1024 --height=768 -- /usr/bin/FreeCAD -t TestCoinNodeSnapshots
        rc=$?

        echo "Test exit code: $rc"
        echo "Generating visual report..."
        report_script="${TMT_TREE}/scripts/coin_snapshot_report.py"

        if [ -f "$report_script" ]; then
          echo "Using report script: $report_script"
          python3 "$report_script" "$OUT" || true
        else
          echo "Report script not found at: $report_script"
        fi

        REPORT="$OUT/report.html"
        # Build public artifact URLs from available env vars. We prefer explicit
        # artifact base urls when available, then fallback to request-id mapping.
        artifact_base=""
        if [ -n "$TESTING_FARM_ARTIFACTS_URL" ]; then
          artifact_base="${TESTING_FARM_ARTIFACTS_URL%/}"
        elif [ -n "$TMT_REPORT_ARTIFACTS_URL" ]; then
          artifact_base="${TMT_REPORT_ARTIFACTS_URL%/}"
        elif [ -n "$TESTING_FARM_REQUEST_ID" ]; then
          artifact_base="https://artifacts.dev.testing-farm.io/${TESTING_FARM_REQUEST_ID}"
        fi

        echo "TESTING_FARM_REQUEST_ID: ${TESTING_FARM_REQUEST_ID:-<unset>}"
        echo "TMT_REPORT_ARTIFACTS_URL: ${TMT_REPORT_ARTIFACTS_URL:-<unset>}"
        echo "TESTING_FARM_ARTIFACTS_URL: ${TESTING_FARM_ARTIFACTS_URL:-<unset>}"
        echo "TMT_TEST_DATA: ${TMT_TEST_DATA:-<unset>}"
        echo "artifact_base: ${artifact_base:-<unset>}"

        if [ -n "$artifact_base" ] && [ -n "$TMT_TEST_DATA" ] && [[ "$TMT_TEST_DATA" == /var/ARTIFACTS/* ]]; then
          workdir_rel="${TMT_TEST_DATA#/var/ARTIFACTS/}"
          snapshots_url="${artifact_base}/${workdir_rel}/CoinNodeSnapshots"
          report_url="${snapshots_url}/report.html"
          echo "CoinNodeSnapshots dir: $snapshots_url/"
        else
          report_url="$REPORT"
        fi
        echo "CoinNodeSnapshots report: $report_url"

        exit $rc
      duration: 60m
